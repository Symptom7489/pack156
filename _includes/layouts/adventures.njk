---
layout: "layouts/base.njk"
---


<section class="section">
  <div class="container">
    <div class="columns is-multiline is-centered">

      <div class="column is-full has-text-left mb-4">
        <a href="/adventures/" class="button is-text is-small">
          &lt; Back to Our Adventures
        </a>
      </div>

      <div class="column is-full has-text-centered">
        <h1 class="title is-2">{{ title }}</h1>
      </div>

      <div class="column is-full has-text-left mt-5">
        <div class="content">
          {% if description %}

           <h3> {{ description | safe }} </h3>
          {% endif %}

          {% if people %}
            <h3>People in this Photo</h3>
            <ul>
              {% for person in people %}
              <li>{{ person.name }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>

    <div class="column is-full has-text-centered mt-5">
      <div class="columns is-multiline is-centered">
        {% for item in photos %}
          <div class="column is-one-quarter-desktop is-one-third-tablet is-half-mobile">
            <a href="{{ item }}" target="_blank">
              <figure class="image is-4by3"> {# Bulma handles the height/ratio automatically #}
                <img src="{{ item }}" 
                    alt="{{ title }}" 
                    style="object-fit: cover; border-radius: 12px;"> {# The Magic sauce #}
              </figure>
            </a>
          </div>
        {% endfor %}
      </div>
    </div>
    </div>
  </div>
</section>
