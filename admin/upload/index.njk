---
layout: "layouts/base.njk"
title: "Photo Uploader"
permalink: /admin/upload/index.html
---

<style>
  #upload-page {
    min-height: 60vh;
  }

  #drop-zone {
    border: 3px dashed #031d44;
    border-radius: 12px;
    padding: 3rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
    background: #f8f9ff;
    position: relative;
  }

  #drop-zone.dragover {
    background: #e8eeff;
    border-color: #F8CF6A;
    transform: scale(1.01);
  }

  #drop-zone input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .preview-item {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 1;
    background: #eee;
  }

  .preview-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .preview-item .status-badge {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 4px 6px;
    font-size: 0.65rem;
    font-weight: bold;
    text-align: center;
  }

  .preview-item .remove-btn {
    position: absolute;
    top: 4px;
    right: 4px;
    background: rgba(0,0,0,0.6);
    color: white;
    border: none;
    border-radius: 50%;
    width: 22px;
    height: 22px;
    cursor: pointer;
    font-size: 0.7rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .status-pending  { background: rgba(0,0,0,0.5); color: white; }
  .status-uploading { background: rgba(248,207,106,0.9); color: #333; }
  .status-done     { background: rgba(35,180,100,0.9); color: white; }
  .status-error    { background: rgba(220,50,50,0.9); color: white; }

  #progress-bar-wrap {
    height: 8px;
    background: #e0e0e0;
    border-radius: 4px;
    overflow: hidden;
    margin-top: 1rem;
  }

  #progress-bar {
    height: 100%;
    background: #031d44;
    width: 0%;
    transition: width 0.3s ease;
  }
</style>

<section class="section" id="upload-page">

  <!-- Login gate -->
  <div class="container" id="login-prompt" style="display:none;">
    <div class="columns is-centered">
      <div class="column is-half has-text-centered">
        <div class="box">
          <figure class="image is-64x64 mx-auto mb-4">
            <img src="/images/background/cub-scout-logo-55x55.png" alt="Pack 156">
          </figure>
          <h1 class="title is-4">Admin Access Required</h1>
          <p class="mb-4">You must be logged in as a pack leader to upload photos.</p>
          <button class="button is-primary" id="login-btn" style="background-color:#031d44;">
            <span class="icon"><i class="fas fa-lock"></i></span>
            <span>Log In</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Upload UI -->
  <div class="container" id="upload-content" style="display:none;">
    <div class="columns is-centered">
      <div class="column is-three-quarters">

        <div class="mb-5 has-text-centered">
          <h1 class="title is-2">📸 Photo Uploader</h1>
          <p class="subtitle is-6">Upload multiple adventure photos directly to the site. No limits, no extra accounts needed.</p>
        </div>

        <!-- Adventure selector -->
        <div class="box mb-5">
          <div class="field">
            <label class="label is-medium">Which adventure are these photos for?</label>
            <div class="control">
              <input class="input is-medium" type="text" id="adventure-name"
                placeholder="e.g. Swamp Tour, Pinewood Derby, Camping Trip..."
                autocomplete="off">
            </div>
            <p class="help">This determines the folder the photos are saved to. Use the same name as the adventure in the CMS.</p>
          </div>
        </div>

        <!-- Drop zone -->
        <div class="box">
          <div id="drop-zone">
            <input type="file" id="file-input" multiple accept="image/*">
            <span class="icon is-large mb-3" style="color:#031d44;">
              <i class="fas fa-cloud-upload-alt fa-3x"></i>
            </span>
            <p class="title is-5 mt-2">Drag & drop photos here</p>
            <p class="subtitle is-6">or click to browse — you can select multiple at once</p>
            <p class="help">JPG, PNG, WEBP supported</p>
          </div>

          <!-- Preview grid -->
          <div class="preview-grid" id="preview-grid"></div>

          <!-- Progress -->
          <div id="progress-wrap" style="display:none;" class="mt-4">
            <div id="progress-bar-wrap">
              <div id="progress-bar"></div>
            </div>
            <p class="help has-text-centered mt-1" id="progress-label">Uploading...</p>
          </div>

          <!-- Upload button -->
          <div class="mt-5" id="upload-btn-wrap" style="display:none;">
            <button class="button is-primary is-fullwidth is-medium" id="upload-btn" style="background-color:#031d44;">
              <span class="icon"><i class="fas fa-upload"></i></span>
              <span id="upload-btn-label">Upload Photos</span>
            </button>
          </div>

          <!-- Results -->
          <div id="results-box" class="notification mt-4" style="display:none;"></div>
        </div>

        <!-- Instructions -->
        <div class="box mt-4">
          <p class="title is-6">📋 After uploading</p>
          <ol>
            <li>Go to the <a href="/admin/">CMS</a> and open the adventure</li>
            <li>In the <strong>Photos</strong> section, click <strong>Add photo</strong></li>
            <li>Type the path shown after upload (e.g. <code>/images/adventures/swamp-tour/photo.jpg</code>)</li>
            <li>Save the adventure</li>
          </ol>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const loginPrompt = document.getElementById('login-prompt');
  const uploadContent = document.getElementById('upload-content');
  const loginBtn = document.getElementById('login-btn');
  const fileInput = document.getElementById('file-input');
  const dropZone = document.getElementById('drop-zone');
  const previewGrid = document.getElementById('preview-grid');
  const uploadBtnWrap = document.getElementById('upload-btn-wrap');
  const uploadBtn = document.getElementById('upload-btn');
  const uploadBtnLabel = document.getElementById('upload-btn-label');
  const progressWrap = document.getElementById('progress-wrap');
  const progressBar = document.getElementById('progress-bar');
  const progressLabel = document.getElementById('progress-label');
  const resultsBox = document.getElementById('results-box');
  const adventureInput = document.getElementById('adventure-name');

  let selectedFiles = [];

  // AUTH DISABLED FOR LOCAL TESTING — re-enable before going live
  showUploader();

  /* if (window.netlifyIdentity) {
    netlifyIdentity.on('init', user => {
      if (user) { showUploader(); } else { showLogin(); }
    });
    netlifyIdentity.on('login', () => { showUploader(); netlifyIdentity.close(); });
    netlifyIdentity.on('logout', () => showLogin());
    loginBtn.addEventListener('click', () => netlifyIdentity.open('login'));
  } */

  function showUploader() {
    loginPrompt.style.display = 'none';
    uploadContent.style.display = 'block';
  }
  function showLogin() {
    loginPrompt.style.display = 'block';
    uploadContent.style.display = 'none';
  }

  // Drag and drop
  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('dragover'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('dragover');
    handleFiles(Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/')));
  });
  fileInput.addEventListener('change', () => {
    handleFiles(Array.from(fileInput.files));
  });

  function handleFiles(files) {
    files.forEach(file => {
      if (selectedFiles.find(f => f.name === file.name)) return;
      selectedFiles.push(file);
      addPreview(file);
    });
    if (selectedFiles.length > 0) uploadBtnWrap.style.display = 'block';
    uploadBtnLabel.textContent = `Upload ${selectedFiles.length} Photo${selectedFiles.length !== 1 ? 's' : ''}`;
  }

  function addPreview(file) {
    const reader = new FileReader();
    reader.onload = (e) => {
      const item = document.createElement('div');
      item.className = 'preview-item';
      item.id = 'preview-' + file.name.replace(/[^a-z0-9]/gi, '_');
      item.innerHTML = `
        <img src="${e.target.result}" alt="${file.name}">
        <div class="status-badge status-pending">Pending</div>
        <button class="remove-btn" data-name="${file.name}"><i class="fas fa-times"></i></button>
      `;
      item.querySelector('.remove-btn').addEventListener('click', () => removeFile(file.name, item));
      previewGrid.appendChild(item);
    };
    reader.readAsDataURL(file);
  }

  function removeFile(name, el) {
    selectedFiles = selectedFiles.filter(f => f.name !== name);
    el.remove();
    if (selectedFiles.length === 0) uploadBtnWrap.style.display = 'none';
    else uploadBtnLabel.textContent = `Upload ${selectedFiles.length} Photo${selectedFiles.length !== 1 ? 's' : ''}`;
  }

  function setStatus(filename, status, label) {
    const id = 'preview-' + filename.replace(/[^a-z0-9]/gi, '_');
    const el = document.getElementById(id);
    if (!el) return;
    const badge = el.querySelector('.status-badge');
    badge.className = 'status-badge status-' + status;
    badge.textContent = label;
  }

  // Upload
  uploadBtn.addEventListener('click', async () => {
    const adventure = adventureInput.value.trim();
    if (!adventure) {
      adventureInput.focus();
      adventureInput.classList.add('is-danger');
      return;
    }
    adventureInput.classList.remove('is-danger');

    if (selectedFiles.length === 0) return;

    uploadBtn.disabled = true;
    progressWrap.style.display = 'block';
    resultsBox.style.display = 'none';

    let done = 0;
    let errors = [];
    let uploaded = [];

    for (const file of selectedFiles) {
      setStatus(file.name, 'uploading', 'Uploading...');
      progressLabel.textContent = `Uploading ${done + 1} of ${selectedFiles.length}...`;

      try {
        const base64 = await toBase64(file);
        const res = await fetch('/.netlify/functions/upload-photo', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            filename: file.name,
            content: base64,
            adventure: adventure
          })
        });

        const data = await res.json();
        if (res.ok && data.success) {
          setStatus(file.name, 'done', '✓ Done');
          uploaded.push(data.path);
        } else {
          setStatus(file.name, 'error', '✗ Failed');
          errors.push(file.name);
        }
      } catch {
        setStatus(file.name, 'error', '✗ Failed');
        errors.push(file.name);
      }

      done++;
      progressBar.style.width = Math.round((done / selectedFiles.length) * 100) + '%';
    }

    progressLabel.textContent = `Done! ${uploaded.length} uploaded${errors.length ? ', ' + errors.length + ' failed' : ''}.`;
    uploadBtn.disabled = false;

    if (uploaded.length > 0) {
      resultsBox.style.display = 'block';
      resultsBox.className = 'notification is-success mt-4';
      resultsBox.innerHTML = `
        <p class="mb-2"><strong>✓ ${uploaded.length} photo${uploaded.length !== 1 ? 's' : ''} uploaded successfully!</strong></p>
        <p class="mb-2 is-size-7">Use these paths in the CMS under the adventure's Photos section:</p>
        <ul>
          ${uploaded.map(p => `<li><code>${p}</code></li>`).join('')}
        </ul>
      `;
    }
    if (errors.length > 0) {
      const errBox = document.createElement('div');
      errBox.className = 'notification is-danger mt-2';
      errBox.innerHTML = `<strong>✗ Failed to upload:</strong> ${errors.join(', ')}`;
      resultsBox.after(errBox);
    }
  });

  function toBase64(file) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result.split(',')[1]);
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }
});
</script>
